# Santi Universe — static site
# Serve index.html as the default page (replaces WordPress's index.php routing)
DirectoryIndex index.html

# Make sure the WordPress front-controller rewrite is OFF for this site
<IfModule mod_rewrite.c>
  RewriteEngine Off
</IfModule>

# Correct MIME types (most hosts set these already)
<IfModule mod_mime.c>
  AddType application/javascript .js
  AddType image/webp .webp
  AddType image/svg+xml .svg
</IfModule>

# Light caching for static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType font/woff2 "access plus 30 days"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>
